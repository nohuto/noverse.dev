---
import config from 'virtual:starlight/user-config';

import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import repoIconSvg from '../../assets/repo.svg?raw';
import terminalIconSvg from '../../assets/terminal.svg?raw';
import { getActiveRepo } from '../../utils/active-repo';

const { id, sidebar } = Astro.locals.starlightRoute;

const activeRepo = getActiveRepo(id, sidebar);
const hasActiveRepo = Boolean(activeRepo && !['index', '404'].includes(activeRepo));
const repoHref = hasActiveRepo ? `https://github.com/nohuto/${activeRepo}` : '';

/**
 * Render the `Search` component if Pagefind is enabled or the default search component has been overridden.
 */
const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <a class="prompt-line" href="/docs/" aria-label="Go to the docs home page">
      <span class="prompt-user">nohuto</span>
      <span class="prompt-sep">@</span>
      <span class="prompt-host">noverse</span>
    </a>
  </div>
  <div class="sl-flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>
  <div class="sl-hidden md:sl-flex print:hidden right-group">
    {
      hasActiveRepo && (
        <a class="header-shortcut" href={repoHref} target="_blank" rel="noopener noreferrer" aria-label={`Open ${activeRepo} repository`}>
          <span aria-hidden="true" class="header-shortcut-icon" set:html={repoIconSvg}></span>
        </a>
      )
    }
    <div class="sl-flex social-icons">
      <SocialIcons />
      <a class="docs-home-link" href="https://noverse.dev/" aria-label="Go to Noverse home">
        <span aria-hidden="true" class="docs-home-icon" set:html={terminalIconSvg}></span>
      </a>
    </div>
    <ThemeSelect />
    <LanguageSelect />
  </div>
</div>

<style>
  @layer starlight.core {
    :global(:root) {
      --sl-nav-height: 2.875rem;
      --sl-nav-pad-y: 0.375rem;
    }

    @media (min-width: 50rem) {
      :global(:root) {
        --sl-nav-height: 2.875rem;
        --sl-nav-pad-x: 1.25rem;
      }
    }

    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.125rem;
      margin: -0.125rem;
      min-width: 0;
    }

    .right-group,
    .social-icons {
      align-items: center;
      gap: 1rem;
    }

    .right-group {
      gap: 0;
      padding-inline-end: 0.5rem;
    }

    .right-group > :global(docs-theme-select),
    .right-group > :global(starlight-lang-select) {
      margin-inline-start: 0.45rem;
    }

    .prompt-line {
      display: inline-flex;
      align-items: center;
      flex-wrap: nowrap;
      gap: 0.15rem;
      min-width: 0;
      color: var(--sl-color-text);
      font-size: 0.83rem;
      line-height: 1;
      letter-spacing: 0.02em;
      text-decoration: none;
      text-transform: lowercase;
      white-space: nowrap;
    }

    .prompt-user,
    .prompt-host {
      color: var(--sl-color-accent);
    }

    .prompt-sep {
      color: var(--sl-color-text);
    }

    .prompt-line:hover .prompt-user,
    .prompt-line:hover .prompt-host,
    .prompt-line:focus-visible .prompt-user,
    .prompt-line:focus-visible .prompt-host {
      color: var(--sl-color-accent-high);
    }

    .prompt-line:focus-visible {
      outline: none;
    }

    .header-shortcut,
    .docs-home-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--sl-color-gray-2);
      line-height: 0;
      text-decoration: none;
    }

    .header-shortcut {
      margin-inline-end: 1rem;
    }

    .header-shortcut:hover,
    .header-shortcut:focus-visible,
    .docs-home-link:hover,
    .docs-home-link:focus-visible {
      color: var(--sl-color-accent-high);
      outline: none;
    }

    .social-icons::after {
      content: '';
      inline-size: 0;
      height: 2rem;
      border-inline-end: 1px solid var(--sl-color-gray-5);
      margin-inline-end: 0.45rem;
    }

    .social-icons::before {
      content: none;
    }

    .header-shortcut-icon,
    .docs-home-icon {
      display: block;
      width: 1em;
      height: 1em;
    }

    .header-shortcut-icon :global(svg),
    .docs-home-icon :global(svg) {
      display: block;
      width: 1em;
      height: 1em;
    }

    .header-shortcut-icon :global(svg) {
      fill: currentColor;
    }

    .docs-home-icon :global(svg) {
      fill: none;
      stroke: currentColor;
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }

      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }

      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
              100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
                (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
                var(--sl-content-width)
            ) / 2
        );
        display: grid;
        grid-template-columns:
          minmax(calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))), auto)
          1fr
          auto;
        align-content: center;
      }
    }
  }
</style>

