---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';
import repoIconSvg from '../../assets/repo.svg?raw';
import terminalIconSvg from '../../assets/terminal.svg?raw';
import { getActiveRepo } from '../../utils/active-repo';

const { id, sidebar } = Astro.locals.starlightRoute;

const activeRepo = getActiveRepo(id, sidebar);
const hasActiveRepo = Boolean(activeRepo && !['index', '404'].includes(activeRepo));
const repoHref = hasActiveRepo ? `https://github.com/nohuto/${activeRepo}` : '';
---

<div class="mobile-preferences sl-flex">
  <div class="mobile-links">
    {
      hasActiveRepo && (
        <a class="mobile-repo-link" href={repoHref} target="_blank" rel="noopener noreferrer" aria-label={`Open ${activeRepo} repository`}>
          <span aria-hidden="true" class="mobile-repo-icon" set:html={repoIconSvg}></span>
        </a>
      )
    }
    <div class="social-icons">
      <SocialIcons />
      <a class="docs-home-link" href="https://noverse.dev/" aria-label="Go to Noverse home">
        <span aria-hidden="true" class="docs-home-icon" set:html={terminalIconSvg}></span>
      </a>
    </div>
  </div>
  <ThemeSelect />
  <LanguageSelect />
</div>

<style>
  @layer starlight.core {
    .mobile-preferences {
      position: relative;
      justify-content: space-between;
      flex-wrap: wrap;
      align-items: center;
      border-top: 1px solid var(--sl-color-gray-6);
      column-gap: 0.75rem;
      row-gap: 0.625rem;
      padding: 0.5rem 0;
    }

    .mobile-links {
      display: inline-flex;
      align-items: center;
      min-width: 0;
      margin-inline-end: auto;
    }

    .social-icons {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding-block: 0;
    }

    .social-icons:empty {
      display: none;
    }

    .social-icons :global(a),
    .docs-home-link,
    .mobile-repo-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.75rem;
      min-height: 1.75rem;
      padding: 0.25rem;
      margin: 0;
      color: var(--sl-color-gray-2);
      text-decoration: none;
    }

    .social-icons :global(a:hover),
    .social-icons :global(a:focus-visible),
    .docs-home-link:hover,
    .docs-home-link:focus-visible,
    .mobile-repo-link:hover,
    .mobile-repo-link:focus-visible {
      color: var(--sl-color-accent-high);
      outline: none;
    }

    .docs-home-icon,
    .mobile-repo-icon {
      display: block;
      width: 1em;
      height: 1em;
    }

    .docs-home-icon :global(svg),
    .mobile-repo-icon :global(svg) {
      display: block;
      width: 1em;
      height: 1em;
    }

    .mobile-repo-icon :global(svg) {
      fill: currentColor;
    }
  }
</style>
