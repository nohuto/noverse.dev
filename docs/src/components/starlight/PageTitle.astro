---
import Default from '@astrojs/starlight/components/PageTitle.astro';
import ViewModeSwitcher from 'starlight-view-modes/components/ViewModeSwitcher.astro';

const { entry } = Astro.locals.starlightRoute;
const isTemplateSplash = entry.data.template === 'splash';
---

{
  isTemplateSplash ? (
    <Default />
  ) : (
    <div class="docs-page-title-row">
      <Default />
      <div class="docs-page-title-switcher">
        <ViewModeSwitcher type="social-links" />
      </div>
    </div>
  )
}

<style>
  .docs-page-title-row {
    display: block;
  }

  .docs-page-title-switcher {
    display: none;
    align-items: center;
    justify-content: flex-end;
    margin-top: 0.35rem;
  }

  body:has(.starlight-view-modes-zen-mode-no-header):has(.starlight-view-modes-zen-mode-no-table-of-contents) .docs-page-title-row {
    display: grid;
    grid-template-columns: 1fr 2rem;
    align-items: center;
  }

  body:has(.starlight-view-modes-zen-mode-no-header):has(.starlight-view-modes-zen-mode-no-table-of-contents) .docs-page-title-switcher {
    display: flex !important;
    margin-top: 0;
  }

  @media (max-width: 50rem) {
    body:has(.starlight-view-modes-zen-mode-no-header) .docs-page-title-row {
      display: grid;
      grid-template-columns: 1fr 2rem;
      align-items: center;
    }

    body:has(.starlight-view-modes-zen-mode-no-header) .docs-page-title-switcher {
      display: flex !important;
      margin-top: 0;
    }
  }
</style>
